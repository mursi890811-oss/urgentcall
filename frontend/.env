EXPO_PUBLIC_BACKEND_URL=https://urgentcall-backend.onrender.com
# Google Sign-In Web Client ID (from Google Cloud Console -> Credentials -> OAuth 2.0
# Client IDs -> the one of type "Web application"). This is NOT the Android client ID -
# the Android client is matched automatically via your app's SHA-1 fingerprint + package
# name and does not need to be referenced here.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
